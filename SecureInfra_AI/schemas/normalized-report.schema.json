{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/secureinfra-ai/schemas/normalized-report.schema.json",
  "title": "SecureInfra AI Normalized Report",
  "description": "Normalized report containing deterministic findings and metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "tool_name",
    "report_type",
    "source_files",
    "generated_at_utc",
    "environment_summary",
    "summary",
    "findings",
    "metadata",
    "notes"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "report_type": {
      "type": "string"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "environment_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "finding.schema.json"
      }
    },
    "correlations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "correlation_id",
          "correlation_type",
          "key",
          "normalized_key",
          "title",
          "severity",
          "finding_ids",
          "finding_count",
          "source_scripts",
          "affected_objects",
          "rationale",
          "recommended_review"
        ],
        "properties": {
          "correlation_id": {
            "type": "string",
            "minLength": 1
          },
          "correlation_type": {
            "type": "string",
            "minLength": 1
          },
          "key": {
            "type": "string",
            "minLength": 1
          },
          "normalized_key": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "Critical",
              "High",
              "Medium",
              "Low",
              "Info"
            ]
          },
          "finding_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "finding_count": {
            "type": "integer"
          },
          "source_scripts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "affected_objects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          },
          "recommended_review": {
            "type": "string"
          }
        }
      }
    },
    "history_comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_id",
        "current_report_id",
        "previous_report_id",
        "previous_source_file",
        "current_generated_at_utc",
        "previous_generated_at_utc",
        "matched_on",
        "new_finding_ids",
        "persistent_finding_ids",
        "resolved_finding_ids",
        "new_count",
        "persistent_count",
        "resolved_count",
        "resolved_findings",
        "notes"
      ],
      "properties": {
        "comparison_id": {
          "type": "string",
          "minLength": 1
        },
        "current_report_id": {
          "type": "string",
          "minLength": 1
        },
        "previous_report_id": {
          "type": "string",
          "minLength": 1
        },
        "previous_source_file": {
          "type": "string"
        },
        "current_generated_at_utc": {
          "type": "string"
        },
        "previous_generated_at_utc": {
          "type": "string"
        },
        "matched_on": {
          "type": "string",
          "enum": [
            "finding_id"
          ]
        },
        "new_finding_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "persistent_finding_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolved_finding_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "new_count": {
          "type": "integer"
        },
        "persistent_count": {
          "type": "integer"
        },
        "resolved_count": {
          "type": "integer"
        },
        "resolved_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "finding_id",
              "title",
              "severity",
              "affected_object",
              "source_script"
            ],
            "properties": {
              "finding_id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "Critical",
                  "High",
                  "Medium",
                  "Low",
                  "Info"
                ]
              },
              "affected_object": {
                "type": "string"
              },
              "source_script": {
                "type": "string"
              }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "monthly_kpi_summary": {
      "type": "object",
      "description": "Deterministic monthly KPI and trend summary. Informational only; does not assert compliance, certification, audit attestation, or official audit status.",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "control_references_by_finding_id": {
          "type": "object",
          "description": "Broad, deterministic control references keyed by normalized finding_id. These references are informational only and do not assert compliance, certification, or audit attestation.",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "framework",
                "control_id",
                "label",
                "mapping_confidence"
              ],
              "properties": {
                "framework": {
                  "type": "string"
                },
                "control_id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "mapping_confidence": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                }
              }
            }
          }
        },
        "control_mapping_summary": {
          "type": "object",
          "description": "Counts of broad control references by framework and control identifier.",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    },
    "report_type_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
